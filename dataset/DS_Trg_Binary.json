{
	"name": "DS_Trg_Binary",
	"properties": {
		"linkedServiceName": {
			"referenceName": "LS_ADLS_GEN2",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"Trg_Filename": {
				"type": "string"
			},
			"Trg_foldername": {
				"type": "string"
			}
		},
		"folder": {
			"name": "ADLS"
		},
		"annotations": [],
		"type": "Binary",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@dataset().Trg_Filename",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@concat('Processed /', dataset().Trg_foldername)",
					"type": "Expression"
				},
				"fileSystem": "qc-container"
			}
		}
	}
}